{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=ReservationServiceDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Seq" ],
    "MinimumLevel": "Information",
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ],
    "Properties": {
      "ServiceName": "ReservationService"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "UserService",
    "Audience": "BookingPlatform",
    "Key": "a-string-secret-at-least-256-bits-long",
    "ExpiryMinutes": 1440
  },
  "Services": {
    "Accommodation": {
      "BaseUrl": "http://localhost:5002"
    }
  },
  "AllowedHosts": "*"
}
